											<div class="swiper-slide" role="group" aria-roledescription="slide">
									<div class="elementor-carousel-image" role="img" aria-label="IMG_0651_1" style="background-image: url(&#039;https://cdn.deepx.ai/wp-content/uploads/2026/06/09102043/IMG_0651_1-scaled.png&#039;)">

			
					</div>
