											<div class="swiper-slide" role="group" aria-roledescription="slide">
									<div class="elementor-carousel-image" role="img" aria-label="1780853100485" style="background-image: url(&#039;https://cdn.deepx.ai/wp-content/uploads/2026/06/09103532/1780853100485.jpg&#039;)">

			
					</div>
