				<div class="elementor-widget-container">
									<div class="elementor-button-wrapper">
					<a class="elementor-button elementor-button-link elementor-size-sm" href="https://www.ultralytics.com/events/live-session/pioneering-innovation-in-edge-ai-with-ultralytics-and-deepx" target="_blank" rel="noopener">
